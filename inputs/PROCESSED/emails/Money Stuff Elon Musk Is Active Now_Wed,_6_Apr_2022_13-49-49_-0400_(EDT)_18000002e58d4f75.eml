cope=3D"itemscope" target=3D"_blank" style=3D"color: #000000; text-decorati=
on: none !important; border-bottom-width: 1px; border-bottom-color: #000000=
; border-bottom-style: solid; background-color: #ccc;"> famously</a>=C2=A0<=
a href=3D"https://link.mail.bloombergbusiness.com/click/27277787.256598/aHR=
0cHM6Ly93d3cuYmxvb21iZXJnLmNvbS9vcGluaW9uL2FydGljbGVzLzIwMTgtMDgtMTMvZnVuZG=
luZy1mb3ItZWxvbi1tdXNrLXMtdGVzbGEtYnV5b3V0LXdhc24tdC1zby1zZWN1cmU_Y21waWQ9Q=
kJEMDQwNjIyX01PTkVZU1RVRkYmdXRtX21lZGl1bT1lbWFpbCZ1dG1fc291cmNlPW5ld3NsZXR0=
ZXImdXRtX3Rlcm09MjIwNDA2JnV0bV9jYW1wYWlnbj1tb25leXN0dWZm/607f07ceef4b8524a3=
