ecoration: none !important; border-bottom-width: 1px; border-bottom-color: =
#000000; border-bottom-style: solid; background-color: #ccc;">few</a> <a hr=
ef=3D"https://link.mail.bloombergbusiness.com/click/34979401.287353/aHR0cHM=
6Ly93d3cuYmxvb21iZXJnLmNvbS9vcGluaW9uL2FydGljbGVzLzIwMjMtMDEtMjMvZXZlcnl0aG=
luZy1pcy1hbHNvLWJhbmstZnJhdWQ_Y21waWQ9QkJEMDQwOTI0X01PTkVZU1RVRkYmdXRtX21lZ=
