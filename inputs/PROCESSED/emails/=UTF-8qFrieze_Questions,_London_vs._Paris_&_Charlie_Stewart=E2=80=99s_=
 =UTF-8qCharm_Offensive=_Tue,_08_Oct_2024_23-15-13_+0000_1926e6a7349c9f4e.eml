2F24%29&utm_content=3DWall+Power+-+SUBSCRIBERS+%2810%2F1%2F24%29&utm_medium=
=3Demail_action&utm_source=3Dcustomer.io&utm_term=3Df6c60617da42abd12a ) we=
re among the day sale standouts. The selections from Sotheby=E2=80=99s upco=
ming Sydell Miller estate sale, the biggest consignment of the season, were=
 also impressive.

In the exhibition, I ran into a friend and collector who=E2=80=99s an extre=
mely active market participant=E2=80=94a man who buys a lot of art because =
he likes it, but also owns more art than he can ever =E2=80=9Cenjoy.=E2=80=
=9D So dealers and auction houses know that he=E2=80=99s a good source for =
works=E2=80=94and also
a prospective buyer. Intriguingly, his take on the current market was somew=
hat different from the dealer who called me earlier in the day. To my frien=
d, the problem with the private market is that there is no compelling reaso=
n to buy or sell. Prices aren=E2=80=99t going up, so you=E2=80=99re not mis=
sing out on an opportunity. He also said, and I assume this is from bitter =
recent experience, that a lot of private deals are getting negotiated but n=
ot consummated.

That=E2=80=99s a problem. For the art market to regain some of its vigor, m=
y friend offered, it needs to create a sense of FOMO that will motivate pri=
vate sales first, and then auction sales.

$(ad3_title) ( https://ad.doubleclick.net/ddm/clk/597683791;406046427;x;gdp=
r=3D$%7BGDPR%7D;gdpr_consent=3D$%7BGDPR_CONSENT_755%7D?utm_campaign=3DWall+=
Power+-+SUBSCRIBERS+%2810%2F8%2F24%29&utm_content=3DWall+Power+-+SUBSCRIBER=
S+%2810%2F1%2F24%29&utm_medium=3Demail_action&utm_source=3Dcustomer.io&utm_=
term=3Df6c60617da42abd12a )

A Tale of Two Cities

I contemplated that thought, on Monday, as I made my way to Christie=E2=80=
=99s. In the lobby, I saw Guy Wildenstein who, earlier in the year, was sen=
tenced in his long-running tax evasion case to house arrest. Maybe he was w=
earing his electronic bracelet? Designer Tom Ford sauntered through, too, s=
ort of anonymous in the milling crowd.

Christie=E2=80=99s London leaders, Keith Gill and Katharine Arnold, have be=
en doing yeoman=E2=80=99s work to combat the idea that London=E2=80=99s art=
 auctions are declining in significance. Part of their strategy was to drop=
 the June sales and concentrate on March and October. A massive 8-by-12-foo=
t hyperrealist self-portrait by Swiss painter Franz Gertsch, dominates Chri=
stie=E2=80=99s exhibition ( https://www.christies.com/en/lot/lot-6500925?ld=
p_breadcrumb=3Dback&utm_campaign=3DWall+Power+-+SUBSCRIBERS+%2810%2F8%2F24%=
29&utm_content=3DWall+Power+-+SUBSCRIBERS+%2810%2F1%2F24%29&utm_medium=3Dem=
ail_action&utm_source=3Dcustomer.io&utm_term=3Df6c60617da42abd12a ). Not we=
ll known to English or American audiences, Gertsch is the subject of a retr=
ospective at Denmark=E2=80=99s influential Louisiana Museum. Estimated at a=
 little more than =C2=A32 million and backed by a third-party guarantee, th=
e painting will be the first Gertsch auctioned for more than =C2=A31 millio=
n since Luciano made $3.3 million in 2017. A striking painting=20
( https://www.christies.com/en/lot/lot-6500960?ldp_breadcrumb=3Dback&utm_ca=
mpaign=3DWall+Power+-+SUBSCRIBERS+%2810%2F8%2F24%29&utm_content=3DWall+Powe=
r+-+SUBSCRIBERS+%2810%2F1%2F24%29&utm_medium=3Demail_action&utm_source=3Dcu=
stomer.io&utm_term=3Df6c60617da42abd12a ) by Emil Nolde, with colors that a=
re reminiscent of Edvard Munch and held in the same family for nearly 70 ye=
ars, is estimated at =C2=A31 million.

Indeed, there were a
number of modern works that looked fresh. The paintings haven=E2=80=99t cha=
nged, but suddenly they seem quite relevant, which likely explains why earl=
y 20th century works are the inflection points at Christie=E2=80=99s. The s=
ale opens with a couple of small Magritte gouaches, particularly a tiny ( h=
ttps://www.christies.com/en/lot/lot-6500917?ldp_breadcrumb=3Dback&utm_campa=
ign=3DWall+Power+-+SUBSCRIBERS+%2810%2F8%2F24%29&utm_content=3DWall+Power+-=
+SUBSCRIBERS+%2810%2F1%2F24%29&utm_medium=3Demail_action&utm_source=3Dcusto=
mer.io&utm_term=3Df6c60617da42abd12a ) Sh=C3=A9h=C3=A9razade, that act as t=
easers for Mica Ertegun=E2=80=99s large vertical Magritte (to be sold in Ne=
w York) on display at the auction house (and already guaranteed by a third =
party at $95 million). There=E2=80=99s also a Vilhelm Hammersh=C3=B8i lands=
cape=20
( https://www.christies.com/en/lot/lot-6500940?ldp_breadcrumb=3Dback&utm_ca=
mpaign=3DWall+Power+-+SUBSCRIBERS+%2810%2F8%2F24%29&utm_content=3DWall+Powe=
r+-+SUBSCRIBERS+%2810%2F1%2F24%29&utm_medium=3Demail_action&utm_source=3Dcu=
stomer.io&utm_term=3Df6c60617da42abd12a ) hoping to replicate the success o=
f another sold in March, which was estimated at around $600,000 but made $2=
=2E9 million. Of course, in June, a d=
ifferent Hammersh=C3=B8i landscape estim=
ated at the same level sold around the estimates. Nothing is guaranteed.

We finished off the auction house tour with a quick stop at the South Afric=
an auction house Strauss & Co., where Alastair Meredith was setting up thei=
r London space to open a private-selling exhibition of African painters dom=
inated by three Irma Stern paintings from across her career, including her =
much-prized Zanzibar works. Then it was off to Bonhams, where Rime Sahmaoui=
 helped us navigate around the caterers setting up a client event to see th=
e works by Etel Adnan, Georgia O=E2=80=99Keeffe, Paul Delvaux, and the some=
what surprising star ( https://www.bonhams.com/auction/30014/lot/2A/helen-l=
undeberg-1908-1999-painting-the-mountain-painted-in-1945/?utm_campaign=3DWa=
ll+Power+-+SUBSCRIBERS+%2810%2F8%2F24%29&utm_content=3DWall+Power+-+SUBSCRI=
BERS+%2810%2F1%2F24%29&utm_medium=3Demail_action&utm_source=3Dcustomer.io&u=
tm_term=3Df6c60617da42abd12a ) of their sale, a Helen Lundeberg post-surrea=
list painting with a very modest estimate of =C2=A330,000.

All these London sales have been created, or at least programmed, to take a=
dvantage of the crowds that typically blow into town for Frieze. But aside =
from the many compelling works on display, there was a sense among some dea=
lers I spoke with that, this year, Paris was more of an emphasis for collec=
tors. This may be just the novelty of Paris growing in scale, or it might p=
resage a larger secular shift that we won=E2=80=99t really know has happene=
d until it=E2=80=99s over. Either way, it=E2=80=99s hard
to imagine the London auctions would go away. But they might ultimately mov=
e a few days closer to Art Basel Paris, if only to allow international coll=
ectors to stop through one fair on their way to the other.

Endnotes=E2=80=A6

I said earlier that planning is key for these trips. But I didn=E2=80=99t r=
eally do such a good job of it, myself. The National Gallery is holding a m=
ajor van Gogh exhibition, but I failed to book my tickets ahead of time. So=
theby=E2=80=99s Tara Rogerson saved the day by getting tickets for me and M=
rs. Wall Power from their Sotheby=E2=80=99s Preferred program. (Thanks agai=
n, Tara.)

We stayed in Bermondsey, in part, to commute via the river. Unfortunately, =
this morning=E2=80=99s intermittent rains made that less than ideal. Instea=
d, we stopped by Borough Market for cr=C3=A8me br=C3=BBl=C3=A9e doughnuts a=
t Bread Ahead.

Van Gogh: Poets and Lovers is a classic big-museum blockbuster. Bring a ste=
pladder to see the art over all the visitors taking pictures with their pho=
nes. From the National Gallery, we took a swing through Philip
Mould=E2=80=99s gallery on our way into St. James to see works by YBA artis=
t Gary Hume at Hazlitt Holland-Hibbert (with more paintings a few blocks aw=
ay at Spr=C3=BCth Magers) and Ren=C3=A9 Dani=C3=ABls at Modern Art. From th=
ere we stopped at Per Skarstedt to see paintings by Marco Pariani; Max Hetz=
ler gallery for new paintings by Andr=C3=A9 Butzer; and Thaddaeus Ropac for=
 a show by Heemin Chung and new work by Robert Longo, whom we passed later =
on New Bond Street. Longo also has similar works at Pace on Hanover Square,=
 which makes the idea of dealers having territories seem to make less and l=
ess sense.

L=C3=A9vy Gorvy Dayan has a thematic show on mysticism and the occult in ar=
t, featuring work by Leonora Carrington, Gertrude Abercrombie, Ithell Colqu=
houn, and many others. David Zwirner has new abstract work by Oscar Murillo=
=2E

I had to drop in at Richard Green
on our way to lunch at Bibi, Chet Sharma=E2=80=99s Indian small plates rest=
aurant, where we had a short version of the tasting menu. Mrs. Wall Power h=
as been working on her sneaker game, so after lunch we headed to Onitsuka b=
efore checking in at Omer Tiroche=E2=80=99s great early Kusama works show, =
Jonas Wood at Gagosian, Hauser & Wirth=E2=80=99s Jack Whitten and George Ro=
uy shows and, finally, Ben Brown Fine Arts for the opening of their Calder =
show.

Then we walked across the bridge to the National Theatre. And I think this =
is where you came in.

Okay. That=E2=80=99s it for today. A lot more to see and do in London, but =
I=E2=80=99m beat.

More on Sunday,
M

