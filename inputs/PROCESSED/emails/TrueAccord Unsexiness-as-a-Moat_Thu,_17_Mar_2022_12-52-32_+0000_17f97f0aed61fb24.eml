3ESaAAlHV9BwIYtNDejMaZcavngaPtp5aV791rCw2n2wJtKiZlPT3r6Y1E-WdV18-H3nB9L2pIV=
fv2cjsVem1WtFf-fGF8E1ELeowVr1U6V3i8F9CJnoqhv_JWQILykYqek-psQ1X5f9NfltuKuw],=
 Lithic [https://email.mg2.substack.com/c/eJxFkN1qxCAQRp8m3m2If2ty4UWh7GsEo=
5Os3USDjg15-9oNtOAozPBxnGMNwhLTqfeYkfxeI5476ABHXgEREikZ0uidpnfWcykG4rRwtJc9=
