# Atlas Personal Knowledge System Configuration Template
# Copy this file to .env and add your actual API key

DATABASE_URL=sqlite:///atlas.db
DATABASE_BACKUP_ENABLED=true
DATABASE_BACKUP_INTERVAL=24h
API_HOST=localhost
API_PORT=7444
API_DEBUG=false

# LLM Configuration - Single Model System
DEFAULT_LLM_PROVIDER=openrouter
DEFAULT_MODEL=google/gemini-2.5-flash-lite
OPENROUTER_API_BASE_URL=https://openrouter.ai/api/v1

# CRITICAL: Add your OpenRouter API key here (starts with sk-or-v1-)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Archive strategy order
ARCHIVE_STRATEGIES=direct,paywall_auth,enhanced_wayback,12ft,archive_today,googlebot,playwright,standard_wayback
