.env
.env.*
.env.secure
.env.local
.env.production
.env.development
!.env.example
!.env.template
secrets/
credentials/
*secret*
*password*
*credential*
*api_key*
*token*
*sk-or-*
*fc-*

# Runtime logs with potentially sensitive content
*.log
!docs/*.log 

# Python cache and virtual environments
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
venv/
.venv/
env/
ENV/
.git/hooks/
.env
!.env.template
.env
!.env.template

