:0;border-left:0\" width=\"100%\">\\n              <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"text_block block-1\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0;word-break:break-word\" width=\"100%\">\\n               <tbody>\\n                <tr>\\n                 <td class=\"pad\" style=\"padding-bottom:5px;padding-top:5px\">\\n                  <div style=\"font-family:\\'Times New Roman\\',Georgia,serif\">\\n                   <div class=\"\" style=\"font-size:12px;font-family:TimesNewRoman,\\'Times New Roman\\',Times,Beskerville,Georgia,serif;mso-line-height-alt:18px;color:#000;line-height:1.5\">\\n                    <p style=\"margin:0;font-size:16px;text-align:center;mso-line-height-alt:45px\">\\n                     <span style=\"word-break: break-word; font-size: 30px; color: #d70a09;\">\\n                      Puck\\xe2\\x80\\x99s Inner Circle Call\\n                     </span>\\n                    </p>\\n                   </div>\\n                  </div>\\n                 </td>\\n                </tr>\\n               </tbody>\\n              </table>\\n              <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"image_block block-2\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0\" width=\"100%\">\\n               <tbody>\\n                <tr>\\n                 <td class=\"pad\" style=\"width:100%\">\\n                  <div align=\"center\" class=\"alignment\" style=\"line-height:10px\">\\n                   <div style=\"max-width:540px\">\\n                    <a href=\"https://email.puck.\" style=\"outline:none\" tabindex=\"-1\" target=\"_blank\">\\n                     <img alt=\"Leigh Ann IC\" height=\"auto\" src=\"https://userimg-assets.customeriomail.com/images/client-env-107382/1739296229327_IC%20leads_2_01JKV24J4TWWFJ9EXSBCEF42XQ.png\" style=\"display:block;height:auto;border:0;width:100%\" title=\"Leigh Ann IC\" width=\"540\"/>\\n                    </a>\\n                   </div>\\n                  </div>\\n                 </td>\\n                </tr>\\n               </tbody>\\n              </table>\\n              <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" class=\"text_block block-3\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0;word-break:break-word\" width=\"100%\">\\n               <tbody>\\n                <tr>\\n                 <td class=\"pad\" style=\"padding-bottom:5px;padding-top:5px\">\\n                  <div style=\"font-family:Arial,sans-serif\">\\n                   <div class=\"\" style=\"font-size:12px;font-family:Arial,\\'Helvetica Neue\\',Helvetica,sans-serif;mso-line-height-alt:18px;color:#000;line-height:1.5\">\\n                    <p style=\"margin:0;font-size:16px;mso-line-height-alt:24px\">\\n                     <span style=\"word-break: break-word; font-size: 16px;\">\\n                      Dear reader,\\n                     </span>\\n                    </p>\\n                    <p style=\"margin:0;font-size:16px;mso-line-height-alt:24px\">\\n                     <span style=\"word-break: break-word; font-size: 16px;\">\\n                     </span>\\n                    </p>\\n                    <p style=\"margin:0;font-size:16px;mso-line-height-alt:24px\">\\n                     <span style=\"word-break: break-word; font-size: 16px;\">\\n                      This Thursday, February 13, at 4 p.m. ET, Puck\\xe2\\x80\\x99s chief Washington correspondent,\\n                      <strong>\\n                       Leigh Ann Caldwell\\n                      </strong>\\n                      , will join the Inner Circle to reveal what her high-level D.C. sources are saying about the latest dramas convulsing Congress: the USAID turmoil, the cabinet nomination circus, and the\\n                      <strong>\\n                       Elon\\n                      </strong>\\n                      <strong>\\n                       Musk\\n                      </strong>\\n                      of it all.\\n                     </span>\\n                     <br/>\\n                     <br/>\\n                     <span style=\"word-break: break-word; font-size: 16px;\">\\n                      As a reminder, these off-the-record calls are reserved for Puck\\xe2\\x80\\x99s Inner Circle, our highest tier of membership, which offers access to exclusive weekly emails, special Puck merch, previews of new product features, and insider discussions just like this one.\\n                     </span>\\n                    </p>\\n                    <p style=\"margin:0;font-size:16px;mso-line-height-alt:18px\">\\n                    </p>\\n                    <p style=\"margin:0;font-size:16px;mso-line-height-alt:24px\">\\n                     <span style=\"word-break: break-word; font-size: 16px;\">\\n                      To join these exclusive conversations with our world-class journalists,\\n                      <a href=\"https://email.puck.\" style=\"text-decoration: underline; color: #d40000;\">\\n                       <strong>\\n                        upgrade\\n                       </strong>\\n                      </a>\\n                      to our Inner Circle tier before tomorrow; you\\xe2\\x80\\x99ll receive an invitation to join the call with Leigh Ann, plus access to\\n                      <strong>\\n                       all future calls and Inner Circle events\\n                      </strong>\\n                      .\\n                     </span>\\n                    </p>\\n                    <p style=\"margin:0;font-size:16px;mso-line-height-alt:18px\">\\n                    </p>\\n                    <p style=\"margin:0;font-size:16px;mso-line-height-alt:24px\">\\n                     <span style=\"word-break: break-word; font-size: 16px;\">\\n                      Click the link below, or go to\\n                      <strong>\\n                       My Account\\n                      </strong>\\n                      &gt;\\n                      <strong>\\n                       Billing\\n                      </strong>\\n                      &gt;\\n                      <strong>\\n                       Update Plan\\n                      </strong>\\n                      and select\\n                      <strong>\\n                       Inner Circle\\n                      </strong>\\n                      . Upon selection, your card on file will be charged for the upgrade, and you\\xe2\\x80\\x99ll immediately become a member of our Inner Circle for the remainder of your subscription.\\n                     </span>\\n                    </p>\\n                    <p style=\"margin:0;font-size:16px;mso-line-height-alt:18px\">\\n                    </p>\\n                    <p style=\"margin:0;font-size:16px;mso-line-height-alt:24px\">\\n                     <span style=\"word-break: break-word; font-size: 16px;\">\\n                      See you on the inside,\\n                     </span>\\n                     <br/>\\n                     <span style=\"word-break: break-word; font-size: 16px;\">\\n                      Fritz\\n                     </span>\\n                    </p>\\n                   </div>\\n                  </div>\\n                 </td>\\n                </tr>\\n               </tbody>\\n              </table>\\n              <table border=\"0\" cellpadding=\"15\" cellspacing=\"0\" class=\"button_block block-4\" role=\"presentation\" style=\"mso-table-lspace:0;mso-table-rspace:0\" width=\"100%\">\\n               <tbody>\\n                <tr>\\n                 <td class=\"pad\">\\n                  <div align=\"center\" class=\"alignment\">\\n                   <!--[if mso]>\\n<v:roundrect xmlns:v=\"urn:schemas-microsoft-com:vml\" xmlns:w=\"urn:schemas-microsoft-com:office:word\" href=\"https://email.puck.\" style=\"height:42px;width:178px;v-text-anchor:middle;\" arcsize=\"10%\" stroke=\"false\" fillcolor=\"#d40000\