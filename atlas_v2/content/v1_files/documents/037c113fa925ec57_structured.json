    {
      "id": 8,
      "type": "NarrativeText",
      "text": "Grow your career",
      "metadata": {
        "parent_id": "9573dc84434569dab45b01d952d34651"
      }
    },
    {
      "id": 9,
      "type": "NarrativeText",
      "text": "From developers and designers to strategists and SAP pros, there are endless opportunities for you to learn, grow and make a difference.",
      "metadata": {
        "parent_id": "9573dc84434569dab45b01d952d34651"
      }
    },
    {
      "id": 10,
      "type": "Text",
      "text": "Artificial intelligence (AI) & data science",
      "metadata": {
        "parent_id": "9573dc84434569dab45b01d952d34651"
      }
    },
    {
      "id": 11,
      "type": "NarrativeText",
      "text": "Unlock the power of AI and data to reinvent all facets of business–responsibly.",
      "metadata": {
        "parent_id": "9573dc84434569dab45b01d952d34651"
      }
    },
    {
      "id": 12,
      "type": "Text",
      "text": "Learn more",
      "metadata": {
        "parent_id": "9573dc84434569dab45b01d952d34651"
      }
    },
    {
      "id": 13,
      "type": "Text",
      "text": "Consulting",
      "metadata": {
        "parent_id": "9573dc84434569dab45b01d952d34651"
      }
    },
    {
      "id": 14,
      "type": "NarrativeText",
      "text": "Industry understanding. Deep insights. Big ideas. You’ll help clients understand what they need to reinvent for the future.",
      "metadata": {
        "parent_id": "9573dc84434569dab45b01d952d34651"
      }
    },
    {
      "id": 15,
      "type": "Text",
      "text": "Learn more",
      "metadata": {
        "parent_id": "9573dc84434569dab45b01d952d34651"
      }
    },
    {
      "id": 16,
      "type": "Text",
      "text": "Engineering & manufacturing",
      "metadata": {
        "parent_id": "9573dc84434569dab45b01d952d34651"
      }
    },
    {
      "id": 17,
      "type": "NarrativeText",
      "text": "Use data, insights, and emerging technology to help clients reimagine what they make—and how they can make it faster, better and more sustainably.",
      "metadata": {
        "parent_id": "9573dc84434569dab45b01d952d34651"
      }
    },
    {
      "id": 18,
      "type": "Text",
      "text": "Learn more",
      "metadata": {
        "parent_id": "9573dc84434569dab45b01d952d34651"
      }
    },
    {
      "id": 19,
      "type": "Text",
      "text": "Operations & delivery",
      "metadata": {
        "parent_id": "9573dc84434569dab45b01d952d34651"
      }
    },
    {
      "id": 20,
      "type": "NarrativeText",
      "text": "Use data, insights and tech to reimagine how people work, moving operations from transactional to transformational.",
      "metadata": {
        "parent_id": "9573dc84434569dab45b01d952d34651"
      }
    },
    {
      "id": 21,
      "type": "Text",
      "text": "Learn more",
