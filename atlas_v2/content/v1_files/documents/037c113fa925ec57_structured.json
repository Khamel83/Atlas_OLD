      "type": "Text",
      "text": "Technology",
      "metadata": {
        "parent_id": "9573dc84434569dab45b01d952d34651"
      }
    },
    {
      "id": 29,
      "type": "NarrativeText",
      "text": "Get hands-on with the technologies that our clients need to reinvent, work in new ways and change the world for the better.",
