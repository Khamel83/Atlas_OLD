        "parent_id": "9573dc84434569dab45b01d952d34651"
      }
    },
    {
      "id": 26,
      "type": "NarrativeText",
      "text": "Success is rooted in smart strategy. Use your insights and strategic thinking to understand how our clients can reinvent to stay ahead of change.",
