        "parent_id": "c522aabad1bd2ecb9b7a5b81df04ee24"
      }
    },
    {
      "id": 36,
      "type": "NarrativeText",
      "text": "You love being on a team and have great communication skills — and you’re ready for hands-on experience to learn while you earn.",
