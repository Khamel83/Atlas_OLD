{
  "raw_data": "b'<!DOCTYPE html>\\n<html style=\"margin:0;width:100%;height:100%;padding:0;font-size:100%;min-width:100%\">\\n <head>\\n  <style type=\"text/css\">\\n   @media screen and (max-width: 480px){\\n.social-btn {\\ndisplay: block !important;\\nwidth: 50px !important;\\nheight: 50px !important;\\nmax-width: 50px !important;\\nmax-height: 50px !important;\\nmin-width: 50px !important;\\nmin-height: 50px !important\\n}\\nimg {\\nmax-width: 480px !important\\n}\\np,\\n            ol,\\n            ul,\\n            li {\\nfont-size: 18px !important;\\nmax-width: 480px !important\\n}\\ntd {\\nmax-width: 480px !important\\n}\\nfigure {\\nmax-width: 480px !important\\n}\\nfigure img {\\nmax-width: 480px !important\\n}\\nli figure {\\nmax-width: 290px !important\\n}\\nli figure img {\\nmax-width: 290px !important\\n}\\nfigcaption {\\nfont-size: 17px !important\\n}\\n}\\n@media screen and (-webkit-min-device-pixel-ratio: 3){\\n#main-cell {\\ndisplay: block !important\\n}\\n}\\n  </style>\\n </head>\\n <body style=\"margin:0;width:100%;height:100%;padding:0;font-size:100%;min-width:100%\">\\n  <div style=\"display:none !important;\\nvisibility:hidden;\\nmso-hide:all;\\nfont-size:1px;\\ncolor:#ffffff;\\nline-height:1px;\\nmax-height:0px;\\nmax-width:0px;\\nopacity:0;\\noverflow:hidden;\">\\n   A note on NBC\\'s changing ratings. Then, Apple is demanding its pound of flesh from Patreon creators, who aren\\'t getting any of the benefits of the App Store Apple says it deserves to be compensated for.\\n  </div>\\n  <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n  </p>\\n  <table align=\"center\" bgcolor=\"#FFFFFF\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"width:100%;padding-left:3px;padding-right:3px;max-width:600px\" width=\"100%\">\\n   <tbody>\\n    <tr>\\n     <td id=\"main-cell\" style=\"max-width:600px;display:none\">\\n      <br/>\\n     </td>\\n     <td style=\"max-width:600px\">\\n      <table>\\n       <tbody>\\n        <tr>\\n         <td style=\"max-width:600px\">\\n          <br/>\\n         </td>\\n        </tr>\\n        <tr>\\n         <td style=\"max-width:600px\">\\n          <table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"border-spacing:0;margin:0 auto;width:100%\">\\n           <tbody>\\n            <tr>\\n             <td align=\"center\" style=\"max-width:600px\" valign=\"top\">\\n              <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"width:100%;text-decoration:none;padding-bottom:15px;font-size:12px;line-height:14px\" width=\"100%\">\\n               <tbody>\\n                <tr>\\n                 <td align=\"left\" style=\"max-width:600px;font-family:Helvetica, Arial, sans-serif;font-size:14px\" valign=\"top\">\\n                  <a href=\"https://stratechery.com/2024/nbc-measurement-apple-and-patreon-substack-next/?access_token=eyJhbGciOiJSUzI1NiIsImtpZCI6InN0cmF0ZWNoZXJ5LnBhc3Nwb3J0Lm9ubGluZSIsInR5cCI6IkpXVCJ9..ldCKvZZZUMima6TDVIax_VGiERbWJTGUoKCYbnyNzVU-6YAiNf7-Wn-qG4Kux3FDJm4odCxg9_-rO-yq2trejtMjkW2dwKXcBosZTIiEvgAERxGvErhoGcjYgOsWXBwV2uGkRmxMXu4g_7b-0xDZIQyqUCcS1GaBuy33X56s8-jELVeHauP70xBxUOo7xyJ8cH44Zhtt1GHqmO0Mja18xCgLbkdCn6p6WVTfM2u_tC81V6_uYcwJ6LPOcS5E1aacqqSksHjtQe-Qnz-6yw2xXDFOiTJlqEyrKZI5FGyDlPZAQg56mfip6OSlD_VYyDm2VEI3M5kkzH_7Pakid1VBFQ\" style=\"font-weight:400;color:#faa634;text-decoration:none\">\\n                   View in browser\\n                  </a>\\n                 </td>\\n                </tr>\\n               </tbody>\\n              </table>\\n              <table align=\"center\" bgcolor=\"#FFFFFF\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"background-color:#ffffff;width:100%\">\\n               <tbody>\\n                <tr>\\n                 <td style=\"max-width:600px\">\\n                  <center>\\n                   <a href=\"https://stratechery.com\" style=\"font-weight:400;color:#faa634;text-decoration:none\" target=\"_blank\">\\n                    <img alt=\"STRATECHERY\" border=\"0\" src=\"https://stratechery.com/wp-content/themes/stratechery-theme/images/header_large.png\" style=\"-ms-interpolation-mode:bicubic;text-align:center;margin:0 auto;width:100%;display:block;color:#000000;font-family:Helvetica, Arial, sans-serif;font-size:24px;font-weight:bold;background-color:#ffffff;outline:none;text-decoration:none;border:none;align-self:center;height:auto;float:center;max-width:400px\" width=\"400\"/>\\n                   </a>\\n                  </center>\\n                 </td>\\n                </tr>\\n               </tbody>\\n              </table>\\n             </td>\\n            </tr>\\n            <tr>\\n             <td style=\"max-width:600px\">\\n              <table align=\"center\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"background-color:#ffffff;width:100%;font-family:Helvetica, Arial, sans-serif\">\\n               <tbody>\\n                <tr>\\n                 <td style=\"max-width:600px\">\\n                  <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"padding-bottom:0px!important;padding-top:0px!important\" width=\"100%\">\\n                   <tbody>\\n                    <tr>\\n                     <td align=\"left\" style=\"max-width:600px;padding-bottom:0\" valign=\"top\">\\n                      <a href=\"https://stratechery.com/2024/nbc-measurement-apple-and-patreon-substack-next/?access_token=eyJhbGciOiJSUzI1NiIsImtpZCI6InN0cmF0ZWNoZXJ5LnBhc3Nwb3J0Lm9ubGluZSIsInR5cCI6IkpXVCJ9..ldCKvZZZUMima6TDVIax_VGiERbWJTGUoKCYbnyNzVU-6YAiNf7-Wn-qG4Kux3FDJm4odCxg9_-rO-yq2trejtMjkW2dwKXcBosZTIiEvgAERxGvErhoGcjYgOsWXBwV2uGkRmxMXu4g_7b-0xDZIQyqUCcS1GaBuy33X56s8-jELVeHauP70xBxUOo7xyJ8cH44Zhtt1GHqmO0Mja18xCgLbkdCn6p6WVTfM2u_tC81V6_uYcwJ6LPOcS5E1aacqqSksHjtQe-Qnz-6yw2xXDFOiTJlqEyrKZI5FGyDlPZAQg56mfip6OSlD_VYyDm2VEI3M5kkzH_7Pakid1VBFQ\" style=\"font-weight:400;color:#faa634;text-decoration:none\">\\n                       <h1 style=\"color:#000000;font-size:24px;font-weight:500;padding-bottom:0px;line-height:125%;font-family:Helvetica, Arial, sans-serif;margin-bottom:0px;text-decoration:none\">\\n                        NBC Measurement, Apple and Patreon, Substack Next?\\n                       </h1>\\n                      </a>\\n                      <span style=\"line-height:130%;display:block;padding-top:5px;padding-bottom:5px;color:#8e8e8e;font-size:14px\">\\n                       Tuesday, August 13, 2024\\n                      </span>\\n                     </td>\\n                    </tr>\\n                   </tbody>\\n                  </table>\\n                  <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"padding-bottom:0px;padding-top:0px\" width=\"100%\">\\n                   <tbody>\\n                    <tr>\\n                     <td align=\"left\" style=\"max-width:600px;font-family:Helvetica, Arial, sans-serif;padding-bottom:0\" valign=\"top\">\\n                      <h4 style=\"font-family:Helvetica, Arial, sans-serif;font-size:20px;line-height:125%;font-weight:500;padding-bottom:2px;padding-top:0px;display:block;text-transform:none;color:#000000;text-decoration:none;margin-bottom:0\">\\n                       <a href=\"https://stratechery.passport.online/member/podcast?url=https%3A%2F%2Frss.stratechery.passport.online%2Ffeed%2Fpodcast%2F6EynvegSpNaDpnt4DJsHzD\" style=\"font-weight:400;color:#faa634;text-decoration:none\" target=\"_blank\">\\n                        Listen to this Update in your podcast player\\n                       </a>\\n                      </h4>\\n                     </td>\\n                    </tr>\\n                   </tbody>\\n                  </table>\\n                  <hr/>\\n                  <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"padding-bottom:0px;padding-top:0px\" width=\"100%\">\\n                   <tbody>\\n                    <tr>\\n                     <td align=\"left\" style=\"max-width:600px;font-family:Helvetica, Arial, sans-serif;padding-bottom:0\" valign=\"top\">\\n                      <meta charset=\"utf-8\"/>\\n                      <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                       Good morning,\\n                      </p>\\n                      <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                       On\\n                       <a href=\"https://sharptech.fm/member/episode/competing-principles-and-u-s-v-google-whats-next-for-apple-questions-on-aggregators-elon-and-crunchyroll\" style=\"font-weight:400;color:#faa634;text-decoration:none\" target=\"_blank\">\\n                        last Thursday\\xe2\\x80\\x99s Sharp Tech\\n                       </a>\\n                       we discussed the competing principles in the U.S. v. Google case, and the implications for Apple.\\n                      </p>\\n                      <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                       On to the Update:\\n                      </p>\\n                      <h3>\\n                       NBC Measurement\\n                      </h3>\\n                      <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                       From Jon Lewis at\\n                       <a href=\"https://www.sportsmediawatch.com/2024/08/paris-olympics-recap-analysis/\" style=\"font-weight:400;color:#faa634;text-decoration:none\" target=\"_blank\">\\n                        Sports Media Watch\\n                       </a>\\n                       :\\n                      </p>\\n                      <table style=\"background:#fffaf0\">\\n                       <tbody class=\"atomic-blockquote-tbody\">\\n                        <tr class=\"atomic-blockquote-tr\">\\n                         <td style=\"max-width:600px;padding-top:0;padding-right:11px;padding-bottom:0;padding-left:15px\">\\n                          <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                           No sports network has ever produced a viewership figure as \\xe2\\x80\\x94 let\\xe2\\x80\\x99s say creative \\xe2\\x80\\x94 as the one that NBC publicized the past two weeks. NBC has always been strategic with its Olympic ratings, for years sanding off the lower-rated early and late portions of its primetime window. (The primetime show might begin at 8 and end at 11:35, but the Nielsen-rated portion might run from 8:30 to 11.) This year, the network made a welcome and long-overdue decision to get with the times and start airing its marquee events live outside of primetime, and that proved incredibly savvy \\xe2\\x80\\x94 as it provided a rationale to start adding three hours of daytime viewership to its primetime audience.\\n                          </p>\\n                          <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                           One might think that is a fair addition, as why should NBC cannibalize itself when the audience is watching the same product? Yet the network\\xe2\\x80\\x99s definition of primetime expanded to cover all manner of afternoon events. NBC\\xe2\\x80\\x99s practice of adding concurrent cable viewing to its primetime figure \\xe2\\x80\\x94 which began with the 2016 Rio Games \\xe2\\x80\\x94 allowed the network to include daytime events that had never before counted to its primetime window, including basketball games and soccer matches on USA that NBC would not typically carry in primetime. The result is a primetime figure that bears no resemblance even to Tokyo in 2021, much less London \\xe2\\x80\\x94 when viewership consisted of a single primetime window on a single network.\\n                          </p>\\n                          <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                           Add to that NBC\\xe2\\x80\\x99s practice of adding Adobe Analytics to its Nielsen figure \\xe2\\x80\\x94 and Nielsen\\xe2\\x80\\x99s inclusion of out-of-home viewing in its estimates \\xe2\\x80\\x94 and one has a viewership figure so inflated relative to past years that it rivaled the hot-air balloon holding the Olympic torch.\\n                          </p>\\n                          <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                           There is no question that viewership increased considerably from Tokyo in 2021, but any comparison to a COVID-era year will be flattering. On an apples-to-apples basis, Paris would probably clock in below Rio, much less London. That is not necessarily an indication of declining popularity, but of changes in television viewing that have afflicted all programming outside of the NFL.\\n                          </p>\\n                         </td>\\n                        </tr>\\n                       </tbody>\\n                      </table>\\n                      <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                       I\\xe2\\x80\\x99m just including this as an addendum to\\n                       <a href=\"https://stratechery.com/2024/olympic-ratings-peacocks-abundance-comcast-earnings/?access_token=eyJhbGciOiJSUzI1NiIsImtpZCI6InN0cmF0ZWNoZXJ5LnBhc3Nwb3J0Lm9ubGluZSIsInR5cCI6IkpXVCJ9..M0dhhYa1zZmq3cjqE9gOrCoyVW5tS_Dlq3xE0YL6N6zMV98W5MRCLaUFfb5Ggh5PhuMdjqi1ZO9zMgG4xJvh41kynt49bCK8cVbD8_WywpIDsSHR9gQBa-qs3T6VbCUoLMxxq3pRR0mwahsHWQs8c6JndOeInFV_hkLu9c5Fh7KAgHg31LaaCRM3ajoLTFyeRwv2cUaAA8B0MI17V7E8rm2aOyeqjWHIM9yc1oWQdiy0ewV4zbR9TKB1A6r-rbNG3BNWNA8bi4C_PxMFEAdZpXvpJbQS2qzq08Q3i-m_IC3VWnbHcAvANX7rxf8RbIbjHWutEJXT7sKDtYymXKQXog\" style=\"font-weight:400;color:#faa634;text-decoration:none\">\\n                        yesterday\\xe2\\x80\\x99s Update\\n                       </a>\\n                       praising NBC\\xe2\\x80\\x99s presentation; I should have pointed out the measurement discrepancy in that piece.\\n                      </p>\\n                      <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                       Ultimately, though, I\\xe2\\x80\\x99m not too bothered by NBC\\xe2\\x80\\x99s \\xe2\\x80\\x9ccreative\\xe2\\x80\\x9d approach. Yes, it is difficult to do apples-to-apples comparisons, but, as Lewis notes in the last paragraph of the excerpt, apples-to-apples comparisons between Olympics are themselves difficult given the dramatically different context between a scarcity-defined world and an abundance-defined one. Expansive measurements that accentuate a strategy predicated on delivering everything are fine by me.\\n                      </p>\\n                      <h3>\\n                       Apple and Patreon\\n                      </h3>\\n                      <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                       From\\n                       <a href=\"https://www.theverge.com/2024/8/12/24218629/patreon-membership-ios-30-percent-apple-tax\" style=\"font-weight:400;color:#faa634;text-decoration:none\" target=\"_blank\">\\n                        The Verge\\n                       </a>\\n                       :\\n                      </p>\\n                      <table style=\"background:#fffaf0\">\\n                       <tbody class=\"atomic-blockquote-tbody\">\\n                        <tr class=\"atomic-blockquote-tr\">\\n                         <td style=\"max-width:600px;padding-top:0;padding-right:11px;padding-bottom:0;padding-left:15px\">\\n                          <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                           Patreon memberships sold on the iOS app will soon be subject to Apple\\xe2\\x80\\x99s 30 percent commission on in-app purchases. In a post on Monday, Patreon says Apple is forcing the platform to use the company\\xe2\\x80\\x99s in-app payment system starting in November or \\xe2\\x80\\x9crisk being kicked out of the App Store.\\xe2\\x80\\x9d As part of the change, creators will need to switch to Patreon\\xe2\\x80\\x99s subscription billing method to keep earning money through the platform\\xe2\\x80\\x99s iOS app. That means Apple\\xe2\\x80\\x99s 30 percent commission will apply when a new membership is initially purchased, as well as each time it\\xe2\\x80\\x99s renewed. To help offset the costs of the new fee, Patreon will give creators the option to automatically increase their prices in the iOS app.\\n                          </p>\\n                         </td>\\n                        </tr>\\n                       </tbody>\\n                      </table>\\n                      <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                       This actually isn\\xe2\\x80\\x99t new news; Patreon announced that these changes were coming soon\\n                       <a href=\"https://news.patreon.com/articles/an-update-on-commerce-purchases-in-the-ios-app\" style=\"font-weight:400;color:#faa634;text-decoration:none\" target=\"_blank\">\\n                        late last year\\n                       </a>\\n                       . And honestly, I\\xe2\\x80\\x99m surprised it took this long: I predicted that Apple would force Patreon to include in-app purchase\\n                       <a href=\"https://stratechery.com/2021/apple-and-creators-fanhouse-and-a-middle-way-pragmatism-and-conversions/?access_token=eyJhbGciOiJSUzI1NiIsImtpZCI6InN0cmF0ZWNoZXJ5LnBhc3Nwb3J0Lm9ubGluZSIsInR5cCI6IkpXVCJ9..KLIlUb0msSTj8vqv7LMhGh-o-918K9xqV_RT5-5B6hKOXHUs9jIxK3uCJitKRmkTuECNeAseog8iMhffjvkPozoMU-pH8PUlQi9aniP5qxPdDH0TvsdmdTKIUZNujE7pG3kmUA6FQW3Zaaz3guZz-YC1YXP2X0c40bPOd4SxWU7xa6MWTV4lnxcQOaKotcHkF_A-0pFsdgh9nTf0j24RaiLiuTubTv8Wf42Z7m-Z0JXojvtDEohE54pfyYzoEhxfUXfn_OVkF_vHtLcFxtyZPI37g3_um4Wr_dC5Zhn4meXvhUbzPtij3mr97nYspA4chWA56xXJ6FCNzJjRRy4crg\" style=\"font-weight:400;color:#faa634;text-decoration:none\">\\n                        back in 2021\\n                       </a>\\n                       , in a classic case of being right on a prediction but wrong on timing (and thus, for the record, wrong!). That prediction was in the context of a similar dispute about Fanhouse, another creator platform that was protesting Apple\\xe2\\x80\\x99s insistence on taking 30% of all subscriptions; it seemed weird that Apple was going after one creator platform and not the larger and more famous one \\xe2\\x80\\x94 and now they have.\\n                      </p>\\n                      <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                       What is much weirder, however, is the callousness with which the App Store treats any sort of creative pursuit that is\\n                       <em>\\n                        not\\n                       </em>\\n                       app development. That may seem like an odd thing to say, given that developers are the most directly impacted by Apple\\xe2\\x80\\x99s App Store policies, but at the end of the day, the App Store is part of the platform on which developers operate \\xe2\\x80\\x94 they are making actual apps, so to some extent it makes sense that if Apple is going to tax someone, it taxes them. Or, to put it in Apple\\xe2\\x80\\x99s preferred terms, all of the IP that they develop that they insist on being compensated for is IP that is directly used by and essential for app development.\\n                      </p>\\n                      <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                       That is not the case for, say, a YouTuber with a Patreon account, or a writer, or an artist. For any of them to directly benefit from Apple\\xe2\\x80\\x99s IP would entail creating an actual app, which is entirely outside their skillset. Instead they go to a platform like Patreon to provide the monetization and customer management tools that let them monetize their creativity; to the extent there is an app involved, it is being created by Patreon, not the individual artists.\\n                      </p>\\n                      <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                       The problem, however, is that Apple isn\\xe2\\x80\\x99t charging Patreon, the actual app maker: they are charging creators, by taking 30% of every subscription. In other words, a $10 subscription made on iOS entails giving $3 to Apple, and only then 8% to Patreon for their service; the creator ends up with $6.44 \\xe2\\x80\\x94\\xc2\\xa0or, to put it another way,\\n                       <a href=\"https://kk.org/thetechnium/1000-true-fans/\" style=\"font-weight:400;color:#faa634;text-decoration:none\" target=\"_blank\">\\n                        1,000 true fans\\n                       </a>\\n                       is now 1,553 true fans-who-subscribe-on-iOS.\\n                      </p>\\n                      <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                       That 30% figure is particularly galling, as Nick Heer notes on\\n                       <a href=\"https://pxlnv.com/linklog/patreon-in-app-purchases/\" style=\"font-weight:400;color:#faa634;text-decoration:none\" target=\"_blank\">\\n                        Pixel Envy\\n                       </a>\\n                       :\\n                      </p>\\n                      <table style=\"background:#fffaf0\">\\n                       <tbody class=\"atomic-blockquote-tbody\">\\n                        <tr class=\"atomic-blockquote-tr\">\\n                         <td style=\"max-width:600px;padding-top:0;padding-right:11px;padding-bottom:0;padding-left:15px\">\\n                          <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                           The 30% fee is also notable. As far as I can tell, only a\\n                           <a href=\"https://graphtreon.com/top-patreon-earners/\" style=\"font-weight:400;color:#faa634;text-decoration:none\" target=\"_blank\">\\n                            handful\\n                           </a>\\n                           of Patreon users would exceed the million-dollar annual threshold for Apple\\xe2\\x80\\x99s\\n                           <a href=\"https://developer.apple.com/app-store/small-business-program/\" style=\"font-weight:400;color:#faa634;text-decoration:none\" target=\"_blank\">\\n                            Small Business Program\\n                           </a>\\n                           . That is, everyone who earns less than a million dollars per year through iOS Patreon pledges should, in theory, fork over a 15% commission rate to Apple. But it appears it is Patreon itself which is subject to the 30% rate. Whether that decision was made by Apple or Patreon, or if it is something which is a consequence of how App Store billing works, is unclear to me. But one thing is true regardless: Apple\\xe2\\x80\\x99s 30% commission is\\n                           <a href=\"https://www.patreon.com/pricing\" style=\"font-weight:400;color:#faa634;text-decoration:none\" target=\"_blank\">\\n                            at least double\\n                           </a>\\n                           the rate charged by Patreon itself, and only the latter has any material effect on the relationship between a creative professional and their supporters.\\n                          </p>\\n                         </td>\\n                        </tr>\\n                       </tbody>\\n                      </table>\\n                      <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                       In short, Apple is taking a percentage of individual creator subscriptions, but it is treating every individual creator as if they are a subsidiary of Patreon. It\\xe2\\x80\\x99s as if Apple can\\xe2\\x80\\x99t even conceive of the possibility of there being any sort of platform other than themselves; they may still market themselves as the company for creators, but their actions suggest they truly don\\xe2\\x80\\x99t care.\\n                      </p>\\n                      <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                       The solution I would propose to this issue of platforms on platforms is what I put forward during the Fanhouse dispute:\\n                      </p>\\n                      <table style=\"background:#fffaf0\">\\n                       <tbody class=\"atomic-blockquote-tbody\">\\n                        <tr class=\"atomic-blockquote-tr\">\\n                         <td style=\"max-width:600px;padding-top:0;padding-right:11px;padding-bottom:0;padding-left:15px\">\\n                          <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                           As\\n                           <a href=\"https://stratechery.com/2021/app-store-arguments/?access_token=eyJhbGciOiJSUzI1NiIsImtpZCI6InN0cmF0ZWNoZXJ5LnBhc3Nwb3J0Lm9ubGluZSIsInR5cCI6IkpXVCJ9..cERRPm2-qvOzPIIRzUpBtOE55Mz1YgNqG7g9-5GSRArOQzcbhZg-jil4uwBsd3vtLLBe9hD4kkFwNr75r1CBCmEVgqYAlT1YIwNWghJLRJZaKNW477JqzRGc_xOqHHL7Upie-MaXYNSxMUFe3alE8TgBL93C3fgvhHOdhkAERkboNfBYMXoR2dtqcZn6H3cffVBjHXBUhJ2lkn2ahTQxWft7fuTebwYkFAnyzpCz6LJd7H_l7QcvZYSHy0oVQun3Wk8wqyNlh-07QaKG0u_-P3tr0XUVqYARWfPNx4gXsVE77-tJAzaK0hdROKqe7UJsZfm_-UjJ6O2ItW24CM3bxw\" style=\"font-weight:400;color:#faa634;text-decoration:none\">\\n                            I have documented\\n                           </a>\\n                           ad nauseum, Apple is, legally speaking, within its rights to collect whatever payments it wants from apps; that is why Rice\\xe2\\x80\\x99s thread is not a legal threat but an appeal to Apple\\xe2\\x80\\x99s better angels, as it were. These two tweets, though, offer what seems to me to be a compelling middle ground: creators benefit from the investment of platforms like Fanhouse, and pay Fanhouse; Fanhouse, meanwhile, benefits from Apple\\xe2\\x80\\x99s creation of the App Store, and can pay Apple. The bit that seems off in all of this is Apple wanting a piece of every transaction in the stack, no matter how far removed said transaction may be from the phone itself.\\n                          </p>\\n                         </td>\\n                        </tr>\\n                       </tbody>\\n                      </table>\\n                      <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                       The way this would play out for the $10 subscription above is that the creator would pay Patreon its 8% fee, which would mean $9.20 for the creator and $0.80 for Patreon; Apple, then, would take 30% from Patreon, i.e. $0.24. This fits Apple\\xe2\\x80\\x99s claimed logic for the App Store: it is creating the IP that enables Patreon\\xe2\\x80\\x99s business, which entails creating the sort of platform that the App Store simply isn\\xe2\\x80\\x99t for non-developer creators. The big problem, though, is that $0.24 is a lot less than $3.00, and Apple has been pretty clear with its actions that money matters much more than the creators it claims to be motivated by.\\n                      </p>\\n                      <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                       Indeed, if we are to take Apple not by its word but by its actions, than the conclusion that they are the truly abusive monopolist is hard to escape. This isn\\xe2\\x80\\x99t Apple monetizing its IP; it\\xe2\\x80\\x99s a tollkeeper collecting rent just because it can.\\n                      </p>\\n                      <h3>\\n                       Substack Next?\\n                      </h3>\\n                      <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                       John Gruber thinks that Patreon simply shouldn\\xe2\\x80\\x99t offer subscriptions in their app; from\\n                       <a href=\"https://daringfireball.net/linked/2024/08/12/heer-patreon-apple\" style=\"font-weight:400;color:#faa634;text-decoration:none\" target=\"_blank\">\\n                        Daring Fireball\\n                       </a>\\n                       :\\n                      </p>\\n                      <table style=\"background:#fffaf0\">\\n                       <tbody class=\"atomic-blockquote-tbody\">\\n                        <tr class=\"atomic-blockquote-tr\">\\n                         <td style=\"max-width:600px;padding-top:0;padding-right:11px;padding-bottom:0;padding-left:15px\">\\n                          <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                           I suppose it\\xe2\\x80\\x99s implicit here that a lot Patreon users go through the iOS app. But I can\\xe2\\x80\\x99t help but think they should do what Substack does and just not allow paid subscriptions through the app. I just double-checked this was still true, and it seems to be. Substack\\xe2\\x80\\x99s iOS app lets you subscribe only to free subscriptions in-app. If you tap \\xe2\\x80\\x9cManage Subscription\\xe2\\x80\\x9d in the app, you\\xe2\\x80\\x99re presented with a sheet that says, unhelpfully, \\xe2\\x80\\x9cYou cannot manage your subscription in the app.\\xe2\\x80\\x9d (It\\xe2\\x80\\x99s Apple\\xe2\\x80\\x99s odious anti-steering rules that disallow apps like Substack from explaining where you can manage your subscription, which, of course, is on the web.)\\n                          </p>\\n                         </td>\\n                        </tr>\\n                       </tbody>\\n                      </table>\\n                      <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                       It\\xe2\\x80\\x99s worth pointing out that Substack is operating in a gray zone as well. The\\n                       <a href=\"https://developer.apple.com/app-store/review/guidelines/\" style=\"font-weight:400;color:#faa634;text-decoration:none\" target=\"_blank\">\\n                        App Review Guidelines\\n                       </a>\\n                       state:\\n                      </p>\\n                      <table style=\"background:#fffaf0\">\\n                       <tbody class=\"atomic-blockquote-tbody\">\\n                        <tr class=\"atomic-blockquote-tr\">\\n                         <td style=\"max-width:600px;padding-top:0;padding-right:11px;padding-bottom:0;padding-left:15px\">\\n                          <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                           If you want to unlock features or functionality within your app, (by way of example: subscriptions, in-game currencies, game levels, access to premium content, or unlocking a full version), you must use in-app purchase. Apps may not use their own mechanisms to unlock content or functionality, such as license keys, augmented reality markers, QR codes, cryptocurrencies and cryptocurrency wallets, etc.\\n                          </p>\\n                         </td>\\n                        </tr>\\n                       </tbody>\\n                      </table>\\n                      <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                       The exception is for so-called \\xe2\\x80\\x9cReader\\xe2\\x80\\x9d apps:\\n                      </p>\\n                      <table style=\"background:#fffaf0\">\\n                       <tbody class=\"atomic-blockquote-tbody\">\\n                        <tr class=\"atomic-blockquote-tr\">\\n                         <td style=\"max-width:600px;padding-top:0;padding-right:11px;padding-bottom:0;padding-left:15px\">\\n                          <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                           Apps may allow a user to access previously purchased content or content subscriptions (specifically: magazines, newspapers, books, audio, music, and video). Reader apps may offer account creation for free tiers, and account management functionality for existing customers. Reader app developers may apply for the External Link Account Entitlement to provide an informational link in their app to a web site the developer owns or maintains responsibility for in order to create or manage an account.\\n                          </p>\\n                         </td>\\n                        </tr>\\n                       </tbody>\\n                      </table>\\n                      <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                       Notice that \\xe2\\x80\\x9cblogs\\xe2\\x80\\x9d are not covered, or art, or whatever else it is that might be offered on Patreon or Substack; that certainly suggests that Apple could go after Substack for not offering in-app purchase in an app that, by definition, has restricted content that is unlocked by a subscription. That would, of course, be a ridiculous thing to do, but when has that stopped Apple?\\n                      </p>\\n                      <hr/>\\n                      <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                       This Update will be available as a podcast later today. To receive it in your podcast player,\\n                       <a href=\"https://stratechery.passport.online/member\" style=\"font-weight:400;color:#faa634;text-decoration:none\" target=\"_blank\">\\n                        visit Stratechery\\n                       </a>\\n                       .\\n                      </p>\\n                      <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                       The Stratechery Update is intended for a single recipient, but occasional forwarding is totally fine! If you would like to order multiple subscriptions for your team with a group discount (minimum 5), please contact me directly.\\n                      </p>\\n                      <p style=\"font-size:17px;font-weight:300;font-family:Helvetica, Arial, sans-serif;margin-top:15px;margin-bottom:15px;padding-top:0px;padding-bottom:0px;line-height:130%\">\\n                       Thanks for being a subscriber, and have a great day!\\n                      </p>\\n                     </td>\\n                    </tr>\\n                   </tbody>\\n                  </table>\\n                  <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"padding-bottom:0px;padding-top:0px\" width=\"100%\">\\n                   <tbody>\\n                    <tr>\\n                     <td align=\"center\" style=\"max-width:600px;font-family:Helvetica, Arial, sans-serif;padding-bottom:0\" valign=\"top\">\\n                      <h4 style=\"font-family:Helvetica, Arial, sans-serif;font-size:20px;line-height:125%;font-weight:500;padding-bottom:2px;padding-top:0px;display:block;text-transform:none;color:#000000;text-decoration:none;margin-bottom:0\">\\n                       Listen to this update and other Stratechery Plus content in your podcast player:\\n                       <a href=\"https://stratechery.passport.online/member/podcast?url=https%3A%2F%2Frss.stratechery.passport.online%2Ffeed%2Fpodcast%2F6EynvegSpNaDpnt4DJsHzD\" style=\"font-weight:400;color:#faa634;text-decoration:none\" target=\"_blank\">\\n                        Stratechery\\n                       </a>\\n                       |\\n                       <a href=\"https://sharptech.fm/member/podcast?url=https%3A%2F%2Fsharptech.fm%2Ffeed%2Fpodcast%2F6EynvegSpNaDpnt4DJsHzD\" style=\"font-weight:400;color:#faa634;text-decoration:none\" target=\"_blank\">\\n                        Sharp Tech\\n                       </a>\\n                       |\\n                       <a href=\"https://dithering.passport.online/member/podcast?url=https%3A%2F%2Frss.dithering.passport.online%2Ffeed%2Fpodcast%2F6EynvegSpNaDpnt4DJsHzD\" style=\"font-weight:400;color:#faa634;text-decoration:none\" target=\"_blank\">\\n                        Dithering\\n                       </a>\\n                       |\\n                       <a href=\"https://sharpchina.fm/member/podcast?url=https%3A%2F%2Fsharpchina.fm%2Ffeed%2Fpodcast%2F6EynvegSpNaDpnt4DJsHzD\" style=\"font-weight:400;color:#faa634;text-decoration:none\" target=\"_blank\">\\n                        Sharp China\\n                       </a>\\n                       |\\n                       <a href=\"https://goat.passport.online/member/podcast?url=https%3A%2F%2Fgoat.passport.online%2Ffeed%2Fpodcast%2F6EynvegSpNaDpnt4DJsHzD\" style=\"font-weight:400;color:#faa634;text-decoration:none\" target=\"_blank\">\\n                        Greatest Of All Talk\\n                       </a>\\n                      </h4>\\n                     </td>\\n                    </tr>\\n                   </tbody>\\n                  </table>\\n                 </td>\\n                </tr>\\n                <tr>\\n                 <td height=\"10\" style=\"max-width:600px\">\\n                  <br/>\\n                 </td>\\n                </tr>\\n               </tbody>\\n              </table>\\n             </td>\\n            </tr>\\n           </tbody>\\n          </table>\\n         </td>\\n        </tr>\\n        <tr>\\n         <td style=\"max-width:600px;background-color:#f6f7f8;text-decoration:none;color:#000000;font-family:Helvetica, Arial, sans-serif;width:100%;font-size:12px;line-height:18px;padding:10px;padding-left:10px;padding-right:10px\">\\n          <table align=\"center\" bgcolor=\"#f6f7f8\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"padding:10px;padding-left:10px;padding-right:10px\" width=\"100%\">\\n           <tbody style=\"padding:10px;padding-left:10px;padding-right:10px\">\\n            <tr style=\"padding:10px;padding-left:10px;padding-right:10px\">\\n             <td style=\"max-width:600px;padding:10px;padding-left:10px;padding-right:10px\">\\n              <span style=\"font-size:20px;font-weight:bold;font-family:Helvetica, Arial, sans-serif\">\\n               Subscription Information\\n               <br/>\\n               <br/>\\n              </span>\\n              <span style=\"font-size:16px;font-weight:normal;font-family:Helvetica, Arial, sans-serif;line-height:140%\">\\n               Member: Omar Zoheri\\n               <br/>\\n               Email:\\n               <a href=\"mailto:stratecheryUSC@khamel.com\" style=\"font-weight:400;color:#000000;font-family:Helvetica,Arial,sans-serif;text-decoration:none\">\\n                stratecheryUSC@khamel.com\\n               </a>\\n     