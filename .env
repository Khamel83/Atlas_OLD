# Project Configuration Template
# This file is SAFE to commit - no real secrets here
# Real secrets are loaded from ~/.secrets/PROJECT_NAME.env

# Common API keys (add more as needed)
OPENROUTER_API_KEY=${OPENROUTER_API_KEY:-your_openrouter_key_here}
FIRECRAWL_API_KEY=${FIRECRAWL_API_KEY:-your_firecrawl_key_here}
DATABASE_URL=${DATABASE_URL:-your_database_url_here}
API_KEY=${API_KEY:-your_api_key_here}
MODEL=${MODEL:-google/gemini-2.0-flash-001}

# Project-specific settings
LOG_LEVEL=${LOG_LEVEL:-INFO}
DEBUG=${DEBUG:-false}
