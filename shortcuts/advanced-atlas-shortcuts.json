{
  "shortcuts": [
    {
      "name": "Smart Atlas Capture",
      "description": "Intelligent content capture with automatic type detection and contextual metadata",
      "icon": "brain.head.profile.fill",
      "color": "blue",
      "version": "2.0",
      "actions": [
        {
          "type": "comment",
          "text": "Get current location with user permission"
        },
        {
          "type": "get_current_location",
          "comment": "Request location for contextual capture"
        },
        {
          "type": "comment",
          "text": "Detect what type of content is being shared"
        },
        {
          "type": "get_input",
          "input_types": ["URL", "Text", "ClipboardContent"],
          "allow_multiple": false,
          "comment": "Get content from various sources"
        },
        {
          "type": "get_details_of_app",
          "app": "CurrentApp",
          "comment": "Get source app information"
        },
        {
          "type": "if_statement",
          "condition": "input_contains_url",
          "then_actions": [
            {
              "type": "set_variable",
              "name": "content_type",
              "value": "url"
            },
            {
              "type": "set_variable", 
              "name": "content",
              "value": "{{input_url}}"
            }
          ],
          "else_actions": [
            {
              "type": "set_variable",
              "name": "content_type",
              "value": "text"
            },
            {
              "type": "set_variable",
              "name": "content", 
              "value": "{{input_text}}"
            }
          ]
        },
        {
          "type": "comment",
          "text": "Test content detection before capturing"
        },
        {
          "type": "http_request",
          "method": "POST",
          "url": "http://YOUR_ATLAS_SERVER:5000/api/capture/detect",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "content": "{{content}}",
            "source_app": "{{app_name}}",
            "capture_context": "share_extension",
            "source_device": "iPhone"
          }
        },
        {
          "type": "get_value",
          "path": "detection.content_type",
          "comment": "Extract detected content type"
        },
        {
          "type": "get_value", 
          "path": "detection.confidence",
          "comment": "Extract confidence score"
        },
        {
          "type": "get_value",
          "path": "detection.processor",
          "comment": "Extract recommended processor"
        },
        {
          "type": "comment",
          "text": "Show detection results to user for confirmation"
        },
        {
          "type": "choose_from_menu",
          "prompt": "Detected: {{detected_type}} ({{confidence}}% confidence)\\n\\nProceed with capture?",
          "options": [
            {
              "label": "Yes, capture it",
              "value": "capture"
            },
            {
              "label": "Let me add notes first",
              "value": "add_notes"
            },
            {
              "label": "Cancel",
              "value": "cancel"
            }
          ]
        },
        {
          "type": "if_statement",
          "condition": "chosen_option == 'cancel'",
          "then_actions": [
            {
              "type": "exit_shortcut"
            }
          ]
        },
        {
          "type": "if_statement",
          "condition": "chosen_option == 'add_notes'",
          "then_actions": [
            {
              "type": "ask_for_input",
              "input_type": "text",
              "prompt": "Add notes for this content:",
              "default": "",
              "allow_multiline": true
            },
            {
              "type": "set_variable",
              "name": "user_notes",
              "value": "{{user_input}}"
            }
          ],
          "else_actions": [
            {
              "type": "set_variable",
              "name": "user_notes",
              "value": ""
            }
          ]
        },
        {
          "type": "comment",
          "text": "Capture content with enhanced metadata"
        },
        {
          "type": "http_request",
          "method": "POST",
          "url": "http://YOUR_ATLAS_SERVER:5000/api/capture",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "type": "{{content_type}}",
            "content": "{{content}}",
            "metadata": {
              "notes": "{{user_notes}}",
              "source": "smart_shortcut_v2",
              "detected_type": "{{detected_type}}",
              "detection_confidence": "{{confidence}}"
            },
            "source_device": "iPhone",
            "location": {
              "latitude": "{{location_latitude}}",
              "longitude": "{{location_longitude}}",
              "accuracy": "{{location_accuracy}}",
              "timestamp": "{{location_timestamp}}"
            },
            "source_app": "{{app_name}}",
            "capture_context": "smart_capture"
          }
        },
        {
          "type": "get_value",
          "path": "capture_id",
          "comment": "Extract capture ID from response"
        },
        {
          "type": "get_value",
          "path": "detection.detected_type",
          "comment": "Get final detected type"
        },
        {
          "type": "get_value",
          "path": "detection.priority",
          "comment": "Get processing priority"
        },
        {
          "type": "show_notification",
          "title": "Atlas Smart Capture",
          "body": "Content captured as {{final_type}}\\nPriority: {{priority}}\\nID: {{capture_id}}"
        }
      ]
    },
    {
      "name": "Batch Atlas Capture",
      "description": "Capture multiple URLs or text items in batch with smart routing",
      "icon": "square.stack.3d.up.fill",
      "color": "orange",
      "version": "2.0",
      "actions": [
        {
          "type": "comment",
          "text": "Get current location once for all captures"
        },
        {
          "type": "get_current_location"
        },
        {
          "type": "get_details_of_app",
          "app": "CurrentApp"
        },
        {
          "type": "comment",
          "text": "Get multiple items to process"
        },
        {
          "type": "ask_for_input",
          "input_type": "text",
          "prompt": "Enter URLs or text items (one per line):",
          "allow_multiline": true
        },
        {
          "type": "split_text",
          "separator": "\\n",
          "comment": "Split input into individual items"
        },
        {
          "type": "set_variable",
          "name": "total_items",
          "value": "{{split_text.count}}"
        },
        {
          "type": "set_variable",
          "name": "processed_count",
          "value": "0"
        },
        {
          "type": "set_variable",
          "name": "success_count", 
          "value": "0"
        },
        {
          "type": "comment",
          "text": "Process each item in the batch"
        },
        {
          "type": "repeat_with_each",
          "items": "{{split_text}}",
          "actions": [
            {
              "type": "set_variable",
              "name": "current_item",
              "value": "{{item}}"
            },
            {
              "type": "calculate",
              "formula": "processed_count + 1",
              "comment": "Increment processed count"
            },
            {
              "type": "set_variable",
              "name": "processed_count",
              "value": "{{calculation_result}}"
            },
            {
              "type": "comment",
              "text": "Skip empty lines"
            },
            {
              "type": "if_statement",
              "condition": "length(trim(current_item)) == 0",
              "then_actions": [
                {
                  "type": "continue_loop"
                }
              ]
            },
            {
              "type": "comment",
              "text": "Determine if item is URL or text"
            },
            {
              "type": "if_statement",
              "condition": "current_item matches_regex '^https?://'",
              "then_actions": [
                {
                  "type": "set_variable",
                  "name": "item_type",
                  "value": "url"
                }
              ],
              "else_actions": [
                {
                  "type": "set_variable",
                  "name": "item_type",
                  "value": "text"
                }
              ]
            },
            {
              "type": "comment",
              "text": "Capture the item"
            },
            {
              "type": "http_request",
              "method": "POST",
              "url": "http://YOUR_ATLAS_SERVER:5000/api/capture",
              "headers": {
                "Content-Type": "application/json"
              },
              "body": {
                "type": "{{item_type}}",
                "content": "{{current_item}}",
                "metadata": {
                  "source": "batch_capture_v2",
                  "batch_info": "{{processed_count}}/{{total_items}}"
                },
                "source_device": "iPhone",
                "location": {
                  "latitude": "{{location_latitude}}",
                  "longitude": "{{location_longitude}}",
                  "accuracy": "{{location_accuracy}}",
                  "timestamp": "{{location_timestamp}}"
                },
                "source_app": "{{app_name}}",
                "capture_context": "batch_processing"
              }
            },
            {
              "type": "if_statement",
              "condition": "http_response.success == true",
              "then_actions": [
                {
                  "type": "calculate",
                  "formula": "success_count + 1"
                },
                {
                  "type": "set_variable",
                  "name": "success_count",
                  "value": "{{calculation_result}}"
                }
              ]
            },
            {
              "type": "comment",
              "text": "Brief pause between items to avoid overwhelming server"
            },
            {
              "type": "wait",
              "seconds": 1
            }
          ]
        },
        {
          "type": "comment",
          "text": "Show final results"
        },
        {
          "type": "show_result",
          "text": "Batch capture complete!\\n\\nProcessed: {{success_count}}/{{total_items}} items\\n\\nAll items are queued for processing and will appear in Atlas within 5-30 minutes."
        }
      ]
    },
    {
      "name": "Context-Aware URL Capture",
      "description": "Capture URLs with enhanced context detection and automatic categorization",
      "icon": "link.circle.fill",
      "color": "green",
      "version": "2.0",
      "actions": [
        {
          "type": "get_current_url",
          "app": "Safari"
        },
        {
          "type": "get_current_location"
        },
        {
          "type": "get_details_of_app",
          "app": "CurrentApp"
        },
        {
          "type": "comment",
          "text": "Get page title and selected text for additional context"
        },
        {
          "type": "get_web_page_contents",
          "url": "{{current_url}}",
          "get_page_contents": false,
          "get_page_selection": true
        },
        {
          "type": "if_statement",
          "condition": "page_selection exists",
          "then_actions": [
            {
              "type": "ask_for_input",
              "input_type": "text",
              "prompt": "Selected text found:\\n\\n{{page_selection}}\\n\\nAdd notes about this selection:",
              "default": "",
              "allow_multiline": true
            }
          ],
          "else_actions": [
            {
              "type": "ask_for_input",
              "input_type": "text",
              "prompt": "Add notes for: {{page_title}}\\n\\nURL: {{current_url}}",
              "default": "",
              "allow_multiline": true
            }
          ]
        },
        {
          "type": "comment",
          "text": "Detect content type and get smart recommendations"
        },
        {
          "type": "http_request",
          "method": "POST",
          "url": "http://YOUR_ATLAS_SERVER:5000/api/capture/detect",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "content": "{{current_url}}",
            "source_app": "{{app_name}}",
            "capture_context": "context_aware_url",
            "source_device": "iPhone"
          }
        },
        {
          "type": "get_value",
          "path": "detection.content_type"
        },
        {
          "type": "get_value",
          "path": "detection.confidence"
        },
        {
          "type": "get_value",
          "path": "processing_recommendations.priority"
        },
        {
          "type": "comment",
          "text": "Capture with full context"
        },
        {
          "type": "http_request",
          "method": "POST",
          "url": "http://YOUR_ATLAS_SERVER:5000/api/capture",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "type": "url",
            "content": "{{current_url}}",
            "metadata": {
              "notes": "{{user_input}}",
              "source": "context_aware_capture_v2",
              "page_title": "{{page_title}}",
              "selected_text": "{{page_selection}}",
              "detected_type": "{{content_type}}",
              "detection_confidence": "{{confidence}}",
              "processing_priority": "{{priority}}"
            },
            "source_device": "iPhone",
            "location": {
              "latitude": "{{location_latitude}}",
              "longitude": "{{location_longitude}}",
              "accuracy": "{{location_accuracy}}",
              "timestamp": "{{location_timestamp}}"
            },
            "source_app": "{{app_name}}",
            "capture_context": "enhanced_url_capture"
          }
        },
        {
          "type": "show_notification",
          "title": "Atlas Context Capture",
          "body": "{{page_title}}\\n\\nDetected: {{content_type}} ({{confidence}}% confident)\\nPriority: {{priority}}"
        }
      ]
    },
    {
      "name": "Smart Voice to Atlas",
      "description": "Enhanced voice capture with automatic transcription and content detection",
      "icon": "mic.circle.fill",
      "color": "red",
      "version": "2.0", 
      "actions": [
        {
          "type": "get_current_location"
        },
        {
          "type": "get_details_of_app",
          "app": "CurrentApp"
        },
        {
          "type": "comment",
          "text": "Record voice with enhanced settings"
        },
        {
          "type": "dictate_text",
          "locale": "en_US",
          "stop_listening": "After Pause",
          "comment": "Record voice memo with auto-stop"
        },
        {
          "type": "if_statement",
          "condition": "dictated_text is empty",
          "then_actions": [
            {
              "type": "show_notification",
              "title": "Atlas Voice Capture",
              "body": "No speech detected. Please try again."
            },
            {
              "type": "exit_shortcut"
            }
          ]
        },
        {
          "type": "comment",
          "text": "Analyze transcribed text for content type"
        },
        {
          "type": "http_request",
          "method": "POST",
          "url": "http://YOUR_ATLAS_SERVER:5000/api/capture/detect",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "content": "{{dictated_text}}",
            "source_app": "{{app_name}}",
            "capture_context": "voice_transcription",
            "source_device": "iPhone"
          }
        },
        {
          "type": "get_value",
          "path": "detection.content_type"
        },
        {
          "type": "get_value",
          "path": "detection.confidence"
        },
        {
          "type": "comment",
          "text": "Show transcription preview with detection results"
        },
        {
          "type": "choose_from_menu",
          "prompt": "Transcription:\\n\\n{{dictated_text}}\\n\\nDetected as: {{content_type}} ({{confidence}}% confidence)\\n\\nWhat would you like to do?",
          "options": [
            {
              "label": "Capture as-is",
              "value": "capture"
            },
            {
              "label": "Edit transcription",
              "value": "edit"
            },
            {
              "label": "Add notes",
              "value": "add_notes"
            },
            {
              "label": "Cancel",
              "value": "cancel"
            }
          ]
        },
        {
          "type": "if_statement",
          "condition": "chosen_option == 'cancel'",
          "then_actions": [
            {
              "type": "exit_shortcut"
            }
          ]
        },
        {
          "type": "set_variable",
          "name": "final_text",
          "value": "{{dictated_text}}"
        },
        {
          "type": "set_variable",
          "name": "notes",
          "value": ""
        },
        {
          "type": "if_statement",
          "condition": "chosen_option == 'edit'",
          "then_actions": [
            {
              "type": "ask_for_input",
              "input_type": "text",
              "prompt": "Edit the transcription:",
              "default": "{{dictated_text}}",
              "allow_multiline": true
            },
            {
              "type": "set_variable",
              "name": "final_text",
              "value": "{{user_input}}"
            }
          ]
        },
        {
          "type": "if_statement",
          "condition": "chosen_option == 'add_notes' OR chosen_option == 'edit'",
          "then_actions": [
            {
              "type": "ask_for_input",
              "input_type": "text",
              "prompt": "Add notes about this voice memo:",
              "default": "",
              "allow_multiline": true
            },
            {
              "type": "set_variable",
              "name": "notes",
              "value": "{{user_input}}"
            }
          ]
        },
        {
          "type": "comment",
          "text": "Capture voice memo with enhanced metadata"
        },
        {
          "type": "http_request",
          "method": "POST",
          "url": "http://YOUR_ATLAS_SERVER:5000/api/capture",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "type": "voice",
            "content": "{{final_text}}",
            "metadata": {
              "notes": "{{notes}}",
              "source": "smart_voice_capture_v2",
              "original_transcription": "{{dictated_text}}",
              "transcription_edited": "{{chosen_option == 'edit'}}",
              "detected_type": "{{content_type}}",
              "detection_confidence": "{{confidence}}",
              "voice_memo": true
            },
            "source_device": "iPhone",
            "location": {
              "latitude": "{{location_latitude}}",
              "longitude": "{{location_longitude}}",
              "accuracy": "{{location_accuracy}}",
              "timestamp": "{{location_timestamp}}"
            },
            "source_app": "{{app_name}}",
            "capture_context": "enhanced_voice_capture"
          }
        },
        {
          "type": "show_result",
          "text": "Voice memo captured successfully!\\n\\nTranscription: {{final_text}}\\n\\nDetected as: {{content_type}}\\n\\nProcessing will complete within 5-30 minutes."
        }
      ]
    },
    {
      "name": "Atlas Quick Actions",
      "description": "Quick menu for common Atlas operations with smart defaults",
      "icon": "star.circle.fill",
      "color": "purple",
      "version": "2.0",
      "actions": [
        {
          "type": "choose_from_menu",
          "prompt": "What would you like to do with Atlas?",
          "options": [
            {
              "label": "🔗 Capture Current URL",
              "value": "url"
            },
            {
              "label": "📝 Quick Text Note",
              "value": "text"
            },
            {
              "label": "🎤 Voice Memo",
              "value": "voice"
            },
            {
              "label": "📋 Clipboard Content",
              "value": "clipboard"
            },
            {
              "label": "📚 Reading List Import",
              "value": "reading_list"
            },
            {
              "label": "❤️ Health Check",
              "value": "health"
            },
            {
              "label": "📊 Recent Captures",
              "value": "recent"
            }
          ]
        },
        {
          "type": "if_statement",
          "condition": "chosen_option == 'url'",
          "then_actions": [
            {
              "type": "run_shortcut",
              "shortcut_name": "Context-Aware URL Capture"
            }
          ]
        },
        {
          "type": "if_statement",
          "condition": "chosen_option == 'voice'",
          "then_actions": [
            {
              "type": "run_shortcut",
              "shortcut_name": "Smart Voice to Atlas"
            }
          ]
        },
        {
          "type": "if_statement",
          "condition": "chosen_option == 'text'",
          "then_actions": [
            {
              "type": "ask_for_input",
              "input_type": "text",
              "prompt": "What would you like to add to Atlas?",
              "allow_multiline": true
            },
            {
              "type": "run_shortcut",
              "shortcut_name": "Smart Atlas Capture",
              "with_input": "{{user_input}}"
            }
          ]
        },
        {
          "type": "if_statement",
          "condition": "chosen_option == 'clipboard'",
          "then_actions": [
            {
              "type": "get_clipboard"
            },
            {
              "type": "run_shortcut",
              "shortcut_name": "Smart Atlas Capture",
              "with_input": "{{clipboard}}"
            }
          ]
        },
        {
          "type": "if_statement",
          "condition": "chosen_option == 'reading_list'",
          "then_actions": [
            {
              "type": "run_shortcut",
              "shortcut_name": "Batch Atlas Capture (Reading List)"
            }
          ]
        },
        {
          "type": "if_statement",
          "condition": "chosen_option == 'health'",
          "then_actions": [
            {
              "type": "http_request",
              "method": "GET",
              "url": "http://YOUR_ATLAS_SERVER:5000/api/capture/health"
            },
            {
              "type": "show_result",
              "text": "Atlas Status: {{status}}\\nService: {{service}}\\nTimestamp: {{timestamp}}"
            }
          ]
        },
        {
          "type": "if_statement",
          "condition": "chosen_option == 'recent'",
          "then_actions": [
            {
              "type": "http_request",
              "method": "GET",
              "url": "http://YOUR_ATLAS_SERVER:5000/api/capture/recent?limit=5"
            },
            {
              "type": "repeat_with_each",
              "items": "{{recent_captures}}",
              "actions": [
                {
                  "type": "text",
                  "text": "{{item.content_type}} - {{item.status}} - {{item.captured_at}}"
                }
              ]
            },
            {
              "type": "show_result",
              "text": "Recent Atlas captures:\\n\\n{{combined_text}}"
            }
          ]
        }
      ]
    }
  ],
  "setup_instructions": {
    "title": "Advanced Atlas Shortcuts Setup (v2.0)",
    "description": "Enhanced shortcuts with contextual awareness, smart detection, and batch processing",
    "steps": [
      "1. Update your Atlas server to the latest version with enhanced capture API",
      "2. Open the Shortcuts app on your iPhone/iPad", 
      "3. Create each shortcut according to the enhanced templates above",
      "4. Replace 'YOUR_ATLAS_SERVER' with your Atlas server IP/URL",
      "5. Grant location permissions when prompted (required for contextual capture)",
      "6. Test each shortcut individually before setting up Siri phrases",
      "7. Add custom Siri phrases for each shortcut",
      "8. Consider creating automation triggers for frequent captures"
    ],
    "new_features": [
      "🧠 Smart content type detection with confidence scoring",
      "📍 Automatic location tagging for contextual organization",
      "🔍 Preview and edit capabilities before capture",
      "📦 Batch processing for multiple items",
      "🎯 Enhanced metadata extraction and processing recommendations",
      "⚡ Quick actions menu for common operations",
      "🔄 Error handling and retry logic"
    ],
    "permissions_required": [
      "Location Services (for contextual capture)",
      "Microphone (for voice memo shortcuts)", 
      "Safari (for Reading List and URL capture)",
      "Notifications (for capture confirmations)"
    ]
  },
  "voice_commands": [
    "Hey Siri, smart Atlas capture",
    "Hey Siri, batch Atlas capture", 
    "Hey Siri, context-aware URL capture",
    "Hey Siri, smart voice to Atlas",
    "Hey Siri, Atlas quick actions"
  ],
  "automation_ideas": [
    {
      "trigger": "When connected to home WiFi",
      "action": "Automatically capture Reading List items",
      "benefit": "Process accumulated articles when at home"
    },
    {
      "trigger": "When leaving work location",
      "action": "Prompt to capture day's notes/thoughts",
      "benefit": "Capture work insights before context is lost"
    },
    {
      "trigger": "When opening specific apps (News, Safari, etc.)",
      "action": "Show quick capture option",
      "benefit": "Seamless capture during content consumption"
    }
  ],
  "troubleshooting": {
    "common_issues": [
      {
        "issue": "Location permission denied",
        "solution": "Go to Settings > Privacy & Security > Location Services > Shortcuts, enable location access"
      },
      {
        "issue": "Content detection fails",
        "solution": "Check Atlas server connectivity and ensure /api/capture/detect endpoint is accessible"
      },
      {
        "issue": "Batch processing times out",
        "solution": "Reduce batch size or increase wait time between items"
