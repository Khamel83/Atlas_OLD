{
  "shortcuts": [
    {
      "name": "Add to Atlas",
      "description": "Send clipboard content to Atlas for processing",
      "icon": "brain.head.profile",
      "color": "blue",
      "actions": [
        {
          "type": "get_clipboard",
          "comment": "Get current clipboard content"
        },
        {
          "type": "http_request",
          "method": "POST",
          "url": "http://YOUR_ATLAS_SERVER:5000/api/capture",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "type": "text",
            "content": "{{clipboard}}",
            "metadata": {
              "source": "siri_shortcut",
              "notes": "Captured via Siri"
            },
            "source_device": "iPhone"
          }
        },
        {
          "type": "show_notification",
          "title": "Atlas Capture",
          "body": "Content sent to Atlas for processing"
        }
      ]
    },
    {
      "name": "Voice to Atlas",
      "description": "Record voice memo and send transcript to Atlas",
      "icon": "mic.fill",
      "color": "red",
      "actions": [
        {
          "type": "dictate_text",
          "locale": "en_US",
          "comment": "Record voice and convert to text"
        },
        {
          "type": "http_request",
          "method": "POST",
          "url": "http://YOUR_ATLAS_SERVER:5000/api/capture",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "type": "voice",
            "content": "{{dictated_text}}",
            "metadata": {
              "source": "voice_shortcut",
              "notes": "Voice memo transcription"
            },
            "source_device": "iPhone"
          }
        },
        {
          "type": "show_result",
          "text": "Voice memo sent to Atlas: {{dictated_text}}"
        }
      ]
    },
    {
      "name": "URL to Atlas",
      "description": "Send current Safari URL to Atlas",
      "icon": "link",
      "color": "green",
      "actions": [
        {
          "type": "get_current_url",
          "app": "Safari",
          "comment": "Get URL from current Safari tab"
        },
        {
          "type": "ask_for_input",
          "input_type": "text",
          "prompt": "Add optional notes for this URL:",
          "default": "",
          "allow_multiline": true
        },
        {
          "type": "http_request",
          "method": "POST",
          "url": "http://YOUR_ATLAS_SERVER:5000/api/capture",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "type": "url",
            "content": "{{current_url}}",
            "metadata": {
              "source": "safari_shortcut",
              "notes": "{{user_input}}"
            },
            "source_device": "iPhone"
          }
        },
        {
          "type": "show_notification",
          "title": "Atlas Capture",
          "body": "URL sent to Atlas: {{current_url}}"
        }
      ]
    },
    {
      "name": "Reading List to Atlas",
      "description": "Bulk export Safari Reading List to Atlas",
      "icon": "book.fill",
      "color": "orange",
      "actions": [
        {
          "type": "get_reading_list",
          "comment": "Get all unread items from Safari Reading List"
        },
        {
          "type": "repeat_with_each",
          "items": "{{reading_list_items}}",
          "actions": [
            {
              "type": "http_request",
              "method": "POST",
              "url": "http://YOUR_ATLAS_SERVER:5000/api/capture",
              "headers": {
                "Content-Type": "application/json"
              },
              "body": {
                "type": "url",
                "content": "{{item.url}}",
                "metadata": {
                  "source": "reading_list_bulk",
                  "notes": "From Safari Reading List: {{item.title}}"
                },
                "source_device": "iPhone"
              }
            },
            {
              "type": "wait",
              "seconds": 1,
              "comment": "Avoid overwhelming the server"
            }
          ]
        },
        {
          "type": "show_result",
          "text": "Sent {{reading_list_items.count}} items from Reading List to Atlas"
        }
      ]
    },
    {
      "name": "Quick Note to Atlas",
      "description": "Quickly capture a text note to Atlas",
      "icon": "note.text",
      "color": "purple",
      "actions": [
        {
          "type": "ask_for_input",
          "input_type": "text",
          "prompt": "What would you like to add to Atlas?",
          "default": "",
          "allow_multiline": true
        },
        {
          "type": "http_request",
          "method": "POST",
          "url": "http://YOUR_ATLAS_SERVER:5000/api/capture",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "type": "text",
            "content": "{{user_input}}",
            "metadata": {
              "source": "quick_note_shortcut",
              "notes": "Quick note via Siri"
            },
            "source_device": "iPhone"
          }
        },
        {
          "type": "show_notification",
          "title": "Atlas Capture",
          "body": "Note added to Atlas knowledge base"
        }
      ]
    },
    {
      "name": "Atlas Health Check",
      "description": "Check if Atlas server is accessible",
      "icon": "heart.circle",
      "color": "gray",
      "actions": [
        {
          "type": "http_request",
          "method": "GET",
          "url": "http://YOUR_ATLAS_SERVER:5000/api/capture/health"
        },
        {
          "type": "get_value",
          "path": "status",
          "comment": "Extract status from response"
        },
        {
          "type": "show_result",
          "text": "Atlas Status: {{status}} at {{timestamp}}"
        }
      ]
    }
  ],
  "setup_instructions": {
    "title": "Atlas Shortcuts Setup",
    "steps": [
      "1. Open the Shortcuts app on your iPhone/iPad",
      "2. Tap the '+' button to create a new shortcut",
      "3. Add actions according to the templates above",
      "4. Replace 'YOUR_ATLAS_SERVER' with your Atlas server IP/URL",
      "5. Test the shortcut and add to Siri for voice activation",
      "6. Say 'Hey Siri, [shortcut name]' to activate"
    ],
    "server_setup": {
      "local_network": "Use your Atlas server's local IP address (e.g., 192.168.1.100:5000)",
      "vpn": "If using VPN, use the VPN IP address of your Atlas server",
      "cloud": "If Atlas is cloud-hosted, use the public URL"
    }
  },
  "voice_commands": [
    "Hey Siri, add to Atlas",
    "Hey Siri, voice to Atlas", 
    "Hey Siri, URL to Atlas",
    "Hey Siri, reading list to Atlas",
    "Hey Siri, quick note to Atlas",
    "Hey Siri, Atlas health check"
  ],
  "troubleshooting": {
    "common_issues": [
      {
        "issue": "Shortcut fails with network error",
        "solution": "Check that your Atlas server URL is correct and accessible from your device"
      },
      {
        "issue": "Voice dictation not working",
        "solution": "Enable Siri & Search in Settings > Siri & Search, and ensure microphone access"
      },
      {
        "issue": "Reading List access denied", 
        "solution": "Grant Shortcuts app access to Safari in Settings > Privacy & Security > Safari"
      },
      {
        "issue": "Shortcuts not appearing in Siri",
        "solution": "Add the shortcut to Siri in the Shortcuts app settings for each shortcut"
      }
    ]
  }
}